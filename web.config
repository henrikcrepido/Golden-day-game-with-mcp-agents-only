<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS web.config for Golden Day Games
  =====================================
  Requirements:
    • IIS 7+ with the URL Rewrite module installed
      (https://www.iis.net/downloads/microsoft/url-rewrite)
    • PHP installed and registered as an IIS FastCGI handler
      (https://www.php.net/manual/en/install.windows.iis7.php)
    • The IIS application-pool identity must have READ+WRITE access to the
      data/ folder so highscores can be persisted to disk.

  What this file does:
    1. Serves index.html as the default document.
    2. Adds the application/json MIME type for .json files.
    3. Rewrites /api/highscores/{key} → /api/highscores.php?key={key}
       so the games' fetch() calls work unchanged.
-->
<configuration>
  <system.webServer>

    <!-- ── Default document ────────────────────────────────────────── -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- ── MIME types ──────────────────────────────────────────────── -->
    <staticContent>
      <!-- Serve .json files as JSON (needed if browsers request them directly) -->
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>

    <!-- ── URL Rewrite rules ────────────────────────────────────────── -->
    <!--
      Requires the IIS URL Rewrite module.
      Download: https://www.iis.net/downloads/microsoft/url-rewrite
    -->
    <rewrite>
      <rules>
        <!--
          Route /api/highscores/{key} to the PHP handler.
          The key may only contain letters, digits, hyphens and underscores
          (1–64 characters) — matching the validation inside highscores.php.
        -->
        <rule name="Highscores API" stopProcessing="true">
          <match url="^api/highscores/([a-zA-Z0-9_-]{1,64})$" />
          <action type="Rewrite" url="/api/highscores.php?key={R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- ── Security: prevent browsing the data/ directory ─────────── -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="data" />
        </hiddenSegments>
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
